# ============================================
# 阿里云配置
# ============================================

# DashScope API Key (统一密钥)
DASHSCOPE_API_KEY=sk-your-api-key-here

# Embedding 独立配置（避免复用 LLM 的 OPENAI_* / LLM_* 配置）
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# Embedding HTTP client proxy behavior
# false: ignore HTTP(S)_PROXY from environment (default, safer for local dev)
# true:  honor HTTP(S)_PROXY from environment (required in proxy deployments)
EMBEDDING_TRUST_ENV=false

# 模型配置加密密钥（必填）
# 生成方式：
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MODEL_CONFIG_ENCRYPTION_KEY=replace-with-your-fernet-key

# TTS 提供商选择
TTS_PROVIDER=aliyun  # aliyun | edge | browser

# TTS 音色配置
TTS_VOICE=longxiaochun  # 龙小春 (温柔女声)

# TTS 采样率
TTS_SAMPLE_RATE=16000

# ============================================
# 降级配置
# ============================================

# 是否启用自动降级
TTS_ENABLE_FALLBACK=true

# 降级顺序
TTS_FALLBACK_CHAIN=aliyun,edge,browser

# ============================================
# 性能配置
# ============================================

# TTS 超时时间 (秒)
TTS_TIMEOUT=10

# 连接池大小
TTS_CONNECTION_POOL_SIZE=10

# 是否预热连接
TTS_ENABLE_WARMUP=true

# ============================================
# StepFun Realtime（双轨语音模式可选）
# ============================================

# 开启 stepfun_realtime 模式时必填
STEPFUN_API_KEY=sk-your-stepfun-api-key

# Realtime 接口与模型
STEPFUN_REALTIME_URL=wss://api.stepfun.com/v1/realtime
STEPFUN_REALTIME_MODEL=step-audio-2  # step-audio-2 | step-audio-r1.1 | step-audio-2-mini | step-1o-audio

# Realtime 输出配置
DEFAULT_VOICE_MODE=stepfun_realtime  # legacy | stepfun_realtime
STEPFUN_REALTIME_VOICE=qingchunshaonv
STEPFUN_REALTIME_INPUT_AUDIO_FORMAT=pcm16
STEPFUN_REALTIME_OUTPUT_AUDIO_FORMAT=pcm16
STEPFUN_REALTIME_OUTPUT_SAMPLE_RATE=24000
STEPFUN_REALTIME_TEMPERATURE=0.7
STEPFUN_REALTIME_INSTRUCTIONS=

# Presentation 会话是否强制要求 agent_id + persona_id 成对传入
PRESENTATION_REQUIRE_AGENT_PERSONA=true

# Grounding diagnostics logging for realtime internal retrieval
# false: keep logs concise (default)
# true: log detailed function-call/retrieval diagnostics for troubleshooting
STEPFUN_GROUNDING_DEBUG_LOG=false
STEPFUN_LATENCY_DEBUG_LOG=false

# KB lock strict-mode timeout budget (milliseconds)
# 超过该时长会触发 blocked_search_timeout（建议 1800~2600）
STEPFUN_KB_LOCK_DECISION_TIMEOUT_MS=2200
# KB lock embedding 阶段预算（毫秒，0=不限制；建议 800~1800）
KNOWLEDGE_KB_LOCK_EMBED_TIMEOUT_MS=1200

# Non-strict prefetch timeout budget (milliseconds)
STEPFUN_GROUNDING_PREFETCH_TIMEOUT_MS=220

# Warmup on realtime session.update for strict KB lock
STEPFUN_KB_LOCK_WARMUP_ENABLED=true

# Auto recover StepFun upstream disconnects without closing frontend WS
STEPFUN_UPSTREAM_AUTO_RECOVER_ENABLED=true
STEPFUN_UPSTREAM_AUTO_RECOVER_MAX_RETRIES=4
STEPFUN_UPSTREAM_AUTO_RECOVER_BASE_DELAY_MS=400
STEPFUN_UPSTREAM_AUTO_RECOVER_MAX_DELAY_MS=5000

# Internal retrieval cache for short-window repeated queries
STEPFUN_INTERNAL_RETRIEVAL_CACHE_TTL_MS=8000
STEPFUN_INTERNAL_RETRIEVAL_CACHE_MAX_ENTRIES=128

# Knowledge retrieval performance knobs
KNOWLEDGE_SEARCH_HEALTH_CACHE_TTL_MS=8000
KNOWLEDGE_READY_DOC_IDS_CACHE_TTL_MS=8000
KNOWLEDGE_RUNTIME_CACHE_MAX_ENTRIES=512
KNOWLEDGE_VECTOR_SEARCH_CONCURRENCY=4
KNOWLEDGE_EMBED_BATCH_ENABLED=true
KNOWLEDGE_STRICT_KEYWORD_FALLBACK_ON_EMPTY_VECTOR=true
KNOWLEDGE_KB_LOCK_MIN_PASS_SCORE=0.62
KNOWLEDGE_KB_LOCK_MIN_PASS_SCORE_KEYWORD=0.55

# ============================================
# WeCom SSO
# ============================================

WECHAT_CORP_ID=your_corp_id
WECHAT_SECRET=your_secret
WECHAT_AGENT_ID=your_agent_id
AUTH_FRONTEND_BASE_URL=http://localhost:3445

# ============================================
# Auth（受控登录）
# ============================================

# 共享登录口令（建议本地开发环境必填）
AUTH_SHARED_PASSWORD=change-me

# 按账号覆盖口令（可选 JSON，优先于共享口令）
# 示例：{"admin@qoder.ai":"admin123","support@qoder.ai":"support123"}
AUTH_USER_PASSWORDS_JSON=
# Optional explicit dev-login gate; defaults to development-only when unset
AUTH_ENABLE_DEV_LOGIN=

# ============================================
# WebSocket 会话状态（Redis 强依赖）
# ============================================

# 会话状态 Redis 连接（为空时回退 REDIS_URL）
SESSION_STATE_REDIS_URL=redis://localhost:6379/0

# 会话状态 key 前缀
SESSION_STATE_KEY_PREFIX=ws:session_state:

# 会话状态 TTL（秒）
SESSION_STATE_TTL_SECONDS=1800

# 健康检查间隔（秒）
SESSION_STATE_CLEANUP_INTERVAL_SECONDS=300
